# Copy to `.env.local` and fill in values. `.env.local` is gitignored.

# Contentful — same Space for CDA + CMA; tokens are different per API
CONTENTFUL_SPACE_ID=
CONTENTFUL_ENVIRONMENT=
# Content Delivery API (read assets / entries)
CONTENTFUL_DELIVERY_ACCESS_TOKEN=
# Content Management API (update assets / entries)
CONTENTFUL_MANAGEMENT_ACCESS_TOKEN=

# Locale for asset Description field when writing via CMA (must exist on the space)
CONTENTFUL_DEFAULT_LOCALE=en-US

# Set to "false" to skip publish after each asset update (draft only)
CONTENTFUL_PUBLISH_AFTER_UPDATE=true

# OpenAI — image descriptions (use server-side only; do not prefix with NEXT_PUBLIC_)
OPENAI_API_KEY=
