# Copy to `.env.local` and fill in values. `.env.local` is gitignored.

# Contentful — same Space for CDA + CMA; tokens are different per API
CONTENTFUL_SPACE_ID=
CONTENTFUL_ENVIRONMENT=
# Content Delivery API (read assets / entries)
CONTENTFUL_DELIVERY_ACCESS_TOKEN=
# Content Management API (update assets / entries)
CONTENTFUL_MANAGEMENT_ACCESS_TOKEN=

# Locale for asset Description field when writing via CMA (must exist on the space)
CONTENTFUL_DEFAULT_LOCALE=en-US

# Set to "false" to skip publish after each asset update (draft only)
CONTENTFUL_PUBLISH_AFTER_UPDATE=true

# Target max CMA requests per second per process (Free tier cap is 7/s)
CONTENTFUL_CMA_MAX_REQUESTS_PER_SECOND=6

# Max retries when CMA still returns rate limit (429); waits 1s between attempts
CONTENTFUL_CMA_MAX_RETRIES=8

# OpenAI parallel requests during description generation
OPENAI_MAX_CONCURRENCY=3

# Parallel push workers (CMA still throttled by per-second limiter)
CONTENTFUL_PUSH_MAX_CONCURRENCY=2

# Node EventEmitter default listener cap. axios + follow-redirects briefly attaches per-request
# error listeners to keep-alive TLS sockets, so heavy concurrent runs need a higher ceiling.
NODE_EVENT_MAX_LISTENERS=100

# OpenAI — image descriptions (use server-side only; do not prefix with NEXT_PUBLIC_)
OPENAI_API_KEY=

# Webhook: set the same value as custom header `X-Webhook-Secret` on the Contentful webhook
CONTENTFUL_WEBHOOK_SECRET=
